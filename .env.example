# BuzzHive app environment configuration.
# Copy this to .env and fill in real values. Do NOT commit .env.

# Environment: development | staging | production
APP_ENV=development

# Supabase (required for auth and user-sensor links)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Firebase (for sensor data, read-only)
# iOS keys
FIREBASE_API_KEY=your-ios-api-key
FIREBASE_APP_ID=your-ios-app-id
# Android keys (falls back to iOS keys if not set)
FIREBASE_APP_ID_ANDROID=your-android-app-id
FIREBASE_API_KEY_ANDROID=your-android-api-key
# Shared
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
