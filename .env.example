# Copy to .env and fill in values. Do not commit .env.
# For Flutter, pass via --dart-define or use flutter_dotenv / envied.

# Supabase (required for auth and user-sensor links)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Firebase (for sensor data read-only)
# FIREBASE_API_KEY=
# FIREBASE_APP_ID=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_PROJECT_ID=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_DATABASE_URL=https://buzz-hive-1c599-default-rtdb.firebaseio.com
# FIREBASE_STORAGE_BUCKET=
