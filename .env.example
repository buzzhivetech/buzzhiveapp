# Copy this file to .env in the project root and fill in values.
# Do not commit .env. The app loads .env at runtime via flutter_dotenv.
# If .env is missing, use: flutter run --dart-define=SUPABASE_URL=... --dart-define=SUPABASE_ANON_KEY=...

# Supabase (required for auth and user-sensor links)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Firebase (for sensor data read-only)
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=https://buzz-hive-1c599-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=
